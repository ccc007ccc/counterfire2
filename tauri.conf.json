{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CounterFire 2",
  "version": "0.1.0",
  "identifier": "dev.ccc007ccc.counterfire2",
  "build": {
    "frontendDist": "frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CounterFire 2",
        "width": 920,
        "height": 620,
        "minWidth": 760,
        "minHeight": 520,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "center": true,
        "windowEffects": {
          "effects": ["acrylic"],
          "color": [12, 14, 20, 210]
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"],
    "resources": ["assets"],
    "category": "Utility",
    "shortDescription": "CS2 击杀触发 CF 风格音效和图标动画",
    "longDescription": "CounterFire 2 listens to CS2 GSI and shows CrossFire-style kill effects through overlay-engine."
  }
}
